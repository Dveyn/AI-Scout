# MyAI — Scout :8080 + Office :8090
# Скопируйте в /etc/nginx/sites-available/myai и включите:
#   sudo ln -s /etc/nginx/sites-available/myai /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Замените YOUR_DOMAIN и пути к SSL-сертификатам (certbot).

upstream scout_backend {
    server 127.0.0.1:8080;
}

upstream office_backend {
    server 127.0.0.1:8090;
}

server {
    listen 80;
    server_name YOUR_DOMAIN;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name YOUR_DOMAIN;

    # ssl_certificate /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;

    client_max_body_size 20m;

    # Scout + Marketing Department
    location / {
        proxy_pass http://scout_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # CEO Office (отдельный префикс или поддомен)
    location /office/ {
        proxy_pass http://office_backend/office/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/events {
        proxy_pass http://office_backend/api/events;
        proxy_http_version 1.1;
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        chunked_transfer_encoding off;
    }
}
