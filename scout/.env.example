# GPTunnel — https://docs.gptunnel.ru/
GPTUNNEL_API_KEY=
GPTUNNEL_BASE_URL=https://gptunnel.ru/v1
GPTUNNEL_MODEL=gpt-4o-mini
GPTUNNEL_USE_WALLET_BALANCE=true

# --- Экономия LLM (рекомендуемые значения) ---
AGENT_LITE_MODE=true
AGENT_MAX_ROUNDS=3
AGENT_MAX_TOOL_CALLS=2
FIT_SCORE_THRESHOLD=65
AGENT_SKILL=outreach-writer
GENERATE_FOLLOWUPS=true
FOLLOWUP_COUNT=1
FOLLOWUP_MIN_FIT_SCORE=75
LLM_DAILY_BUDGET_RUB=50

# IndexLift SEO — только для слабых сайтов (score < 70 или 2+ проблем)
INDEXLIFT_ENABLED=true
INDEXLIFT_ONLY_BELOW_SCORE=70
INDEXLIFT_MIN_ISSUES=2
INDEXLIFT_TIER=basic
INDEXLIFT_MODE=single-page
INDEXLIFT_ENGINES=google,yandex
INDEXLIFT_TIMEOUT_SEC=90

DATABASE_URL=sqlite+aiosqlite:///./data/scout.db
PLAYWRIGHT_HEADLESS=true

# Сбор лидов: yandex (Playwright) | 2gis (официальный API) | auto (2GIS если есть ключ)
MAPS_COLLECTOR=yandex
# TWOGIS_API_KEY=

# DaData — жёсткий фильтр выручки (finance.revenue, ₽/год → сравниваем с порогом ₽/мес)
# https://dadata.ru/api/suggest/party/
# DADATA_API_KEY=
REVENUE_FILTER_ENABLED=false
ICP_MIN_MONTHLY_REVENUE_RUB=500000
REVENUE_FILTER_STRICT=false

# SMTP — без настроек письма остаются черновиками в UI
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ВебШтрих
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TLS_REJECT_UNAUTHORIZED=0

# Автоотправка + антиспам
AUTO_SEND_EMAIL=true
AUTO_SEND_MIN_FIT_SCORE=70
MAX_EMAILS_PER_DAY=20
MAX_EMAILS_PER_HOUR=6
MAX_EMAILS_PER_DOMAIN_PER_DAY=1
SEND_DELAY_SEC_MIN=60
SEND_DELAY_SEC_MAX=180

# Автопилот
AUTOPILOT_ENABLED=true
AUTOPILOT_MAX_RUNS_PER_DAY=1
FOLLOWUP_DELAY_DAYS=3
FOLLOWUP_DELAY_DAYS_TOUCH3=7

# Telegram: дайджест кампаний + READY-лиды + ответы с почты
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# IMAP — проверка ответов (обычно тот же ящик, что SMTP)
IMAP_CHECK_ENABLED=false
# IMAP_HOST=imap.yandex.ru
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=
# IMAP_USE_SSL=true

# Сервер (PM2)
SCOUT_BIND_HOST=127.0.0.1
SCOUT_BIND_PORT=8080
SCOUT_AUTH_USER=admin
SCOUT_AUTH_PASSWORD=
SCOUT_SECRET_KEY=
SCOUT_REQUIRE_AUTH=false

# --- AI Marketing Department ---
DEPARTMENT_ENABLED=true
DEPARTMENT_TEST_MODE=true
DEPARTMENT_LOCAL_INTERVAL_MIN=60
# cursor = CMO/SMM/SEO/Analytics в Cursor (не GPTunnel); local = всё через GPTunnel
DEPARTMENT_LLM_PROVIDER=cursor
# Только аутрич на картах использует GPTunnel
SCOUT_OUTREACH_LLM_ENABLED=true
CMO_MODE=auto
CMO_AUTO_APPROVE_SMM=true
CMO_AUTO_APPROVE_SEO=true
CMO_AUTO_APPROVE_ADS=false

# SMM publishers (отдельно от TELEGRAM_CHAT_ID дайджеста)
# VK_ACCESS_TOKEN=
# VK_GROUP_ID=
# TELEGRAM_CHANNEL_ID=

# Analytics manual inputs (для ROMI/CPL)
MONTHLY_AD_BUDGET_RUB=0
MONTHLY_REVENUE_RUB=0

# Office CEO tasks → Cursor Automation (создайте automation из .cursor/automations/office-directive.yaml)
OFFICE_LLM_PROVIDER=cursor
# CURSOR_WEBHOOK_OFFICE_DIRECTIVE=https://api2.cursor.sh/automations/webhook/...
# Если не задан — fallback на CURSOR_WEBHOOK_DEPARTMENT_DAILY
# Без пробелов вокруг = ; значение в одну строку без кавычек
# CURSOR_WEBHOOK_DEPARTMENT_DAILY=https://api2.cursor.sh/automations/webhook/...
# CURSOR_WEBHOOK_API_KEY=crsr_ваш_ключ
